---
import Layout from "../layouts/Layout.astro";
---

<Layout title="People" description="Members of the LEAP Lab at Rutgers University">
  <section class="page-header">
    <h1>People</h1>
    <p class="subtitle">
      We are a growing group of researchers at Rutgers University working at the
      intersection of energy systems and artificial intelligence.
    </p>
  </section>

  <section class="group">
    <h2 class="group-label">Principal Investigator</h2>
    <div class="person pi">
      <img class="person-photo" src="/images/qs.jpg" alt="Qichen Song" />
      <div class="person-info">
        <h3>Qichen Song</h3>
        <p class="role">Assistant Professor</p>
        <p class="affil">
          <a href="https://mae.rutgers.edu/">Department of Mechanical and Aerospace Engineering</a><br />
          <a href="https://www.rutgers.edu/">Rutgers, The State University of New Jersey</a>
        </p>
        <p class="bio">
          I am an Assistant Professor in the Department of Mechanical and
          Aerospace Engineering at Rutgers University since September 2026.
          Previously, I was a <a href="https://quantum.harvard.edu/hqi-prize-postdoctoral-fellows">Harvard Quantum Initiative Postdoctoral Fellow</a> at
          Harvard University, hosted by <a href="https://www.mason.chemistry.harvard.edu/">Prof. Jarad A. Mason</a> in the Department
          of Chemistry and Chemical Biology, and worked closely with Prof. Julia
          <a href="http://mundy.physics.harvard.edu/">A. Mundy</a> in the Department of Physics. In 2022, I obtained my
          Ph.D. in Mechanical Engineering from MIT, advised by <a href="https://web.mit.edu/nanoengineering/">Prof. Gang Chen</a>.
        </p>
        <p class="bio">
          I am interested in understanding, manipulating, and optimizing the
          conversion, transfer, and storage of energy in stimuli-responsive
          materials and energy systems, using tools including laser
          spectroscopy, synthetic chemistry, and ab initio calculations, to
          address challenges in energy and sustainability research.
        </p>
        <div class="person-links">
          <a href="mailto:qichen.song@rutgers.edu">qichen.song@rutgers.edu</a>
          <a href="/CV_Qichen_Song.pdf">CV</a>
          <!-- <a href="">Google Scholar</a> -->
        </div>
      </div>
    </div>
  </section>

  <section class="group">
    <h2 class="group-label">Graduate Students</h2>
    <p class="placeholder-note">Openings available — see <a href="/contact">Contact</a> for information.</p>
  </section>

  <section class="group">
    <h2 class="group-label">Undergraduate Researchers</h2>
    <p class="placeholder-note">Coming soon.</p>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: 2.4rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .subtitle {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 600px;
    line-height: 1.7;
  }

  .group {
    margin-bottom: 3rem;
  }

  .group-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .person {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .person-photo {
    width: 135px;
    height: 135px;
    border-radius: 4px;
    object-fit: cover;
    flex-shrink: 0;
    margin-top: 0.3rem;
  }

  .person-info h3 {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .role {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .affil {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .affil a {
    color: var(--text-muted);
    text-decoration: underline;
    text-decoration-color: var(--border);
    transition: color 0.15s;
  }

  .affil a:hover {
    color: var(--accent);
  }

  .bio {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 0.75rem;
  }

  .bio a {
    color: var(--text-muted);
    text-decoration: underline;
    text-decoration-color: var(--border);
    transition: color 0.15s;
  }

  .bio a:hover {
    color: var(--accent);
  }

  .person-links {
    display: flex;
    gap: 1rem;
  }

  .person-links a {
    font-size: 0.85rem;
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
  }

  .person-links a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .placeholder-note {
    font-size: 0.85rem;
    color: #aaa;
  }

  .placeholder-note a {
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .placeholder-note a:hover {
    color: var(--accent);
  }

  @media (max-width: 480px) {
    .person {
      flex-direction: column;
    }
  }
</style>
